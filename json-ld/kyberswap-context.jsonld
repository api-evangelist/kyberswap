      "@id": "kyberswap:tickLower",
      "@type": "xsd:integer"
    },
    "tickUpper": {
      "@id": "kyberswap:tickUpper",
      "@type": "xsd:integer"
    },
    "liquidity": {
      "@id": "kyberswap:liquidity",
      "@type": "xsd:string"
    },
    "tokenAddress": {
      "@id": "kyberswap:tokenAddress",
      "@type": "xsd:string"
    },
    "price": {
      "@id": "schema:price",
      "@type": "xsd:decimal"
    },
